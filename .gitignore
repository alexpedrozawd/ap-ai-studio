__pycache__/
*.pyc
.pytest_cache/

# webui: build output gerado por `npm run build` (vfx-web-build) - nao versionado,
# regenera a partir de webui/frontend/. node_modules idem, ja coberto pelo
# webui/frontend/.gitignore proprio, mas listado aqui tambem por seguranca.
webui/backend/static/
node_modules/

# dados/instalacoes pesadas relocadas para dentro do projeto (ver simlinks em ~/ai_pipeline e ~/miniconda3)
/ai_pipeline/
/miniconda3/

# midia de trabalho relocada pra dentro do projeto (antes eram simlinks em ~/cenas e ~/fotos, hoje
# sao diretorios reais aqui dentro) - nunca versionar: cenas de filme protegidas por direitos autorais
# e fotos reais da familia.
/cenas/
/fotos/
/videos/
/photos/
/media/

# saida gerada pelo pipeline (ComfyUI/FaceFusion) - imagens/videos com rosto de pessoas reais,
# nunca deve ir pro repo mesmo que /ai_pipeline/ abaixo falhe em cobrir algum caminho novo
/ai_pipeline/*/output/
/ai_pipeline/*/outputs/

# fila de jobs local (metadados de execucao, referencia caminhos pessoais) - estado runtime, nao codigo
/.jobs/

# rede de seguranca: nenhum arquivo de foto/video/audio deve ser versionado em lugar nenhum do repo,
# mesmo fora dos diretorios acima (protege contra um arquivo solto esquecido em qualquer pasta nova).
# .svg fica de fora da lista de propósito: são os ícones do frontend (webui/frontend), texto, não mídia.
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.webp
*.heic
*.tiff
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.wav
*.mp3
*.flac
*.psd
*.raw
*.cr2
*.nef
